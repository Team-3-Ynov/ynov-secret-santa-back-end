# ===================================================================
# Secret Santa API - Variables d'environnement
# ===================================================================
# Copiez ce fichier en .env et remplissez les valeurs

# === Application ===
NODE_ENV=development
PORT=3000

# === Base de donnees PostgreSQL ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secret_santa
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# === JWT ===
JWT_SECRET=your_jwt_secret_here_min_32_characters

# === CORS ===
# Liste des origines autorisees (separees par des virgules)
CORS_ORIGIN=http://localhost:3001

# ===================================================================
# Variables Docker Compose (pour le deploiement)
# ===================================================================

# Tag de l'image Docker
IMAGE_TAG=latest

# Port Nginx
NGINX_PORT=80

# Proprietaire du repo GitHub (pour ghcr.io)
GITHUB_REPOSITORY_OWNER=your_github_username
