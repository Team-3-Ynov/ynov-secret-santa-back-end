{
	"name": "ynov-secret-santa-back-end",
	"version": "1.0.0",
	"description": "Secret Santa API Backend",
	"main": "dist/index.js",
	"scripts": {
		"dev": "nodemon --exec ts-node src/index.ts",
		"dev:services": "docker-compose -f docker-compose.yml --profile infra up -d",
		"dev:services:down": "docker-compose -f docker-compose.yml --profile infra down",
		"dev:services:logs": "docker-compose -f docker-compose.yml --profile infra logs -f",
		"build": "tsc && cp -r src/docs dist/docs",
		"start": "node dist/index.js",
		"migrate": "ts-node scripts/migrate.ts",
		"seed:dev": "ts-node scripts/seed-dev.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"docker:build": "docker build -f docker/Dockerfile -t secret-santa-backend .",
		"docker:down": "docker compose down"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"dependencies": {
		"@sentry/node": "^10.38.0",
		"@sentry/tracing": "^7.120.4",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.2.1",
		"helmet": "^8.1.0",
		"js-yaml": "^4.1.1",
		"jsonwebtoken": "^9.0.3",
		"nodemailer": "^7.0.12",
		"pg": "^8.16.3",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-rate-limit": "^6.0.2",
		"@types/helmet": "^4.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.0.1",
		"@types/nodemailer": "^7.0.5",
		"@types/pg": "^8.16.0",
		"@types/supertest": "^6.0.3",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.0",
		"nodemon": "^3.1.11",
		"supertest": "^7.1.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
